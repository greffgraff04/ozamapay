generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String?
  phone       String?
  role        UserRole @default(USER)
  isSuspended Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactionPin String?

  referredByAgentId String?
  referredByAgent   Agent?  @relation("AgentReferrals", fields: [referredByAgentId], references: [id])

  adminLogs       AdminActionLog[]
  agent           Agent?
  kyc             Kyc?
  notifications   Notification[]
  serviceRequests ServiceRequest[]
  topups          TopUpRequest[]
  virtualCards    VirtualCard[]
  wallet          Wallet?
  withdrawals     WithdrawalRequest[]
  emailVerified   Boolean             @default(false)

  emailVerificationToken String?
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?
  emailVerifiedAt        DateTime?

  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  googleId String? @unique

  photoUrl String?

  strowalletCustomerId String?

  subscriptionTier   String    @default("FREE")
  subscriptionExpiry DateTime?

  failedLoginAttempts Int       @default(0)
  loginLockedUntil    DateTime?

  adminInvitationToken String?
  adminSetupComplete   Boolean @default(false)

  adminSessions        AdminSession[]
  giftCardOrders       GiftCardOrder[]
  airtimeOrders        AirtimeOrder[]
  merchantApplications MerchantApplication[]
  ownedBusinesses      Business[]            @relation("OwnedBusinesses")
  businessMemberships  BusinessMember[]      @relation("BusinessMemberships")
  businessPayments     BusinessTransaction[] @relation("BusinessPayments")

  teamMember TeamMember?

  @@index([email])
  @@index([role])
}

model Wallet {
  id                   String        @id @default(uuid())
  userId               String        @unique
  balance              Decimal       @default(0.00) @db.Decimal(18, 2)
  currency             String        @default("HTG")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  ledgerEntries        LedgerEntry[]
  receivedTransactions Transaction[] @relation("ReceiverTransactions")
  sentTransactions     Transaction[] @relation("SenderTransactions")
  user                 User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transaction {
  id               String            @id @default(uuid())
  reference        String            @unique
  senderWalletId   String?
  receiverWalletId String?
  amount           Decimal           @db.Decimal(18, 2)
  fee              Decimal           @default(0.00) @db.Decimal(18, 2)
  netAmount        Decimal           @db.Decimal(18, 2)
  type             TransactionType
  status           TransactionStatus @default(PENDING)
  method           String?
  title            String?
  description      String?
  proofImage       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  commissions      Commission[]
  ledgerEntries    LedgerEntry[]
  receiverWallet   Wallet?           @relation("ReceiverTransactions", fields: [receiverWalletId], references: [id])
  senderWallet     Wallet?           @relation("SenderTransactions", fields: [senderWalletId], references: [id])

  @@index([reference])
  @@index([status])
  @@index([type])
  @@index([senderWalletId])
  @@index([receiverWalletId])
  @@index([createdAt])
}

model LedgerEntry {
  id            String      @id @default(uuid())
  walletId      String
  transactionId String
  type          LedgerType
  amount        Decimal     @db.Decimal(18, 2)
  balanceBefore Decimal     @db.Decimal(18, 2)
  balanceAfter  Decimal     @db.Decimal(18, 2)
  description   String?
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  wallet        Wallet      @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([transactionId])
}

model TopUpRequest {
  id            String            @id @default(uuid())
  userId        String
  amount        Decimal           @db.Decimal(18, 2)
  fee           Decimal           @db.Decimal(18, 2)
  totalAmount   Decimal           @db.Decimal(18, 2)
  method        String
  proofImage    String?
  status        TransactionStatus @default(PENDING)
  adminNote     String?
  completedById String?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  agentId       String?
  agent         Agent?            @relation(fields: [agentId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([agentId])
  @@index([status])
}

model WithdrawalRequest {
  id            String            @id @default(uuid())
  userId        String
  amount        Decimal           @db.Decimal(18, 2)
  fee           Decimal           @db.Decimal(18, 2)
  netAmount     Decimal           @db.Decimal(18, 2)
  method        String
  accountInfo   String
  status        TransactionStatus @default(PENDING)
  adminNote     String?
  proofImage    String?
  completedById String?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  agentId       String?
  agent         Agent?            @relation(fields: [agentId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([agentId])
  @@index([status])
}

model ServiceRequest {
  id          String            @id @default(uuid())
  userId      String
  serviceType ServiceType
  amount      Decimal           @db.Decimal(18, 2)
  fee         Decimal           @default(0.00) @db.Decimal(18, 2)
  details     String?
  proofImage  String?
  status      TransactionStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([serviceType])
}

model Kyc {
  id          String    @id @default(cuid())
  userId      String    @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime
  phoneNumber String
  idType      String
  idNumber    String
  idImage     String
  userPhoto   String
  line1       String
  city        String
  state       String
  zipCode     String
  country     String
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  agentId     String?
  status      KYCStatus @default(PENDING)
  agent       Agent?    @relation(fields: [agentId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([agentId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ExchangeRateHistory {
  id        String   @id @default(uuid())
  pair      String
  rate      Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now())

  @@index([pair])
}

model Agent {
  id                    String              @id @default(uuid())
  userId                String              @unique
  businessName          String?
  status                AgentStatus         @default(PENDING)
  commissionRate        Decimal             @default(0.00) @db.Decimal(5, 2)
  dailyLimit            Decimal             @default(0.00) @db.Decimal(18, 2)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  agentCode             String              @unique
  level                 AgentLevel          @default(BRONZE)
  totalCommission       Decimal             @default(0.00) @db.Decimal(18, 2)
  totalKyc              Int                 @default(0)
  totalTopupVolume      Decimal             @default(0.00) @db.Decimal(18, 2)
  totalWithdrawalVolume Decimal             @default(0.00) @db.Decimal(18, 2)
  trustScore            Decimal             @default(100.00) @db.Decimal(5, 2)
  user                  User                @relation(fields: [userId], references: [id])
  wallet                AgentWallet?
  commissions           Commission[]
  kycs                  Kyc[]
  topups                TopUpRequest[]
  withdrawals           WithdrawalRequest[]
  referredUsers         User[]              @relation("AgentReferrals")
  liquidityRequests     LiquidityRequest[]
}

model AgentWallet {
  id        String   @id @default(uuid())
  agentId   String   @unique
  balance   Decimal  @default(0.00) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model Commission {
  id            String         @id @default(uuid())
  agentId       String
  transactionId String?
  type          CommissionType
  amount        Decimal        @db.Decimal(18, 2)
  createdAt     DateTime       @default(now())
  agent         Agent          @relation(fields: [agentId], references: [id])
  transaction   Transaction?   @relation(fields: [transactionId], references: [id])

  @@index([agentId])
  @@index([transactionId])
}

model AdminActionLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
}

model Rate {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Decimal  @db.Decimal(18, 4)
  currency  String   @default("HTG")
  updatedAt DateTime @updatedAt
}

model VirtualCard {
  id        String     @id @default(uuid())
  userId    String
  cardId    String     @unique
  cardName  String?
  last4     String?
  expiry    String?
  brand     String     @default("VISA")
  balance   Decimal    @default(0.00) @db.Decimal(18, 2)
  currency  String     @default("USD")
  provider  String     @default("STROWALLET_NFC")
  status    CardStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([cardId])
  @@index([status])
}

enum UserRole {
  USER
  AGENT
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum TransactionType {
  TRANSFER
  PAYMENT
  TOPUP
  WITHDRAWAL
  CARD
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
  CANCELLED
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceType {
  WISE
  MERU
  ZELLE
  CASHAPP
  NATCASH
  USDT
  GAMING
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum CardStatus {
  ACTIVE
  FROZEN
  TERMINATED
}

enum AgentLevel {
  BRONZE
  SILVER
  GOLD
  BLACK
}

enum CommissionType {
  TOPUP
  WITHDRAWAL
  KYC
}

enum BusinessTier {
  STARTER
  PRO
  ENTERPRISE
}

enum BusinessApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessMemberRole {
  OWNER
  ACCOUNTANT
  CASHIER
}

enum BusinessTransactionType {
  PAYMENT_RECEIVED
  WITHDRAWAL
  TRANSFER_OUT
  TOPUP
}

model AdminInvitation {
  id        String   @id @default(uuid())
  email     String   @unique
  role      UserRole
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)
  invitedBy String
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model DailyAccessCode {
  id          String   @id @default(uuid())
  code        String
  generatedAt DateTime @default(now())
  expiresAt   DateTime
  isActive    Boolean  @default(true)

  @@index([isActive])
}

model AdminSession {
  id        String    @id @default(uuid())
  userId    String
  loginAt   DateTime  @default(now())
  logoutAt  DateTime?
  ipAddress String?
  userAgent String?
  isActive  Boolean   @default(true)
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isActive])
}

model MerchantApplication {
  id           String                    @id @default(uuid())
  businessName String
  email        String
  phone        String
  address      String
  plan         String                    @default("STARTER")
  tier         BusinessTier              @default(STARTER)
  status       BusinessApplicationStatus @default(PENDING)
  userId       String?
  adminNote    String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  user         User?                     @relation(fields: [userId], references: [id])
  business     Business?
}

enum LiquidityMethod {
  MONCASH
  ZELLE
  CASH
  BANK
}

enum LiquidityRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model GiftCardOrder {
  id          String   @id @default(uuid())
  userId      String
  productId   Int
  productName String
  unitPrice   Decimal  @db.Decimal(10, 2)
  htgPaid     Decimal  @db.Decimal(18, 2)
  redeemCode  String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model AirtimeOrder {
  id            String   @id @default(uuid())
  userId        String
  operatorId    Int
  operatorName  String
  amount        Decimal  @db.Decimal(18, 2)
  htgPaid       Decimal  @db.Decimal(18, 2)
  phoneNumber   String
  status        String   @default("PENDING")
  transactionId String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model LiquidityRequest {
  id          String                 @id @default(uuid())
  agentId     String
  amount      Decimal                @db.Decimal(18, 2)
  method      LiquidityMethod
  accountInfo String
  status      LiquidityRequestStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  agent       Agent                  @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([status])
}

model Business {
  id                String                    @id @default(uuid())
  businessName      String
  category          String
  tier              BusinessTier
  status            BusinessApplicationStatus @default(PENDING)
  ownerId           String
  applicationId     String                    @unique
  testWalletBalance Decimal                   @default(1000000.00) @db.Decimal(18, 2)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  owner             User                      @relation("OwnedBusinesses", fields: [ownerId], references: [id])
  application       MerchantApplication       @relation(fields: [applicationId], references: [id])
  wallet            BusinessWallet?
  members           BusinessMember[]
  apiKeys           ApiKey[]
  webhooks          WebhookEndpoint[]
  apiPayments       ApiPayment[]
  testTransactions  TestTransaction[]

  @@index([ownerId])
  @@index([status])
}

model BusinessWallet {
  id           String                @id @default(uuid())
  businessId   String                @unique
  balance      Decimal               @default(0.00) @db.Decimal(18, 2)
  currency     String                @default("HTG")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  business     Business              @relation(fields: [businessId], references: [id])
  transactions BusinessTransaction[]
}

model BusinessMember {
  id         String             @id @default(uuid())
  businessId String
  userId     String
  role       BusinessMemberRole
  invitedAt  DateTime           @default(now())
  acceptedAt DateTime?
  createdAt  DateTime           @default(now())
  business   Business           @relation(fields: [businessId], references: [id])
  user       User               @relation("BusinessMemberships", fields: [userId], references: [id])

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
}

model BusinessTransaction {
  id               String                  @id @default(uuid())
  businessWalletId String
  type             BusinessTransactionType
  amount           Decimal                 @db.Decimal(18, 2)
  fee              Decimal                 @default(0.00) @db.Decimal(18, 2)
  netAmount        Decimal                 @db.Decimal(18, 2)
  reference        String                  @unique
  status           TransactionStatus       @default(PENDING)
  payerUserId      String?
  description      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  businessWallet   BusinessWallet          @relation(fields: [businessWalletId], references: [id])
  payer            User?                   @relation("BusinessPayments", fields: [payerUserId], references: [id])

  @@index([businessWalletId])
  @@index([status])
  @@index([createdAt])
}

enum ApiKeyMode {
  LIVE
  TEST
}

enum ApiKeyPermission {
  READ
  WRITE
  WEBHOOK
}

enum ApiPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model ApiKey {
  id          String             @id @default(uuid())
  businessId  String
  name        String
  keyPrefix   String
  keyHash     String             @unique
  mode        ApiKeyMode
  permissions ApiKeyPermission[]
  isActive    Boolean            @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime           @default(now())
  revokedAt   DateTime?

  business         Business          @relation(fields: [businessId], references: [id])
  apiPayments      ApiPayment[]
  testTransactions TestTransaction[]

  @@index([businessId])
  @@index([keyHash])
}

model WebhookEndpoint {
  id         String   @id @default(uuid())
  businessId String
  url        String
  events     String[]
  secret     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model ApiPayment {
  id          String           @id @default(uuid())
  businessId  String
  apiKeyId    String
  amount      Decimal          @db.Decimal(18, 2)
  currency    String           @default("HTG")
  fee         Decimal          @default(0.00) @db.Decimal(18, 2)
  reference   String           @unique
  description String?
  status      ApiPaymentStatus @default(PENDING)
  payerUserId String?
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  business Business @relation(fields: [businessId], references: [id])
  apiKey   ApiKey   @relation(fields: [apiKeyId], references: [id])

  @@index([businessId])
  @@index([status])
}

model TestTransaction {
  id          String           @id @default(uuid())
  businessId  String
  apiKeyId    String
  amount      Decimal          @db.Decimal(18, 2)
  fee         Decimal          @default(0.00) @db.Decimal(18, 2)
  reference   String           @unique
  description String?
  status      ApiPaymentStatus @default(COMPLETED)
  createdAt   DateTime         @default(now())

  business Business @relation(fields: [businessId], references: [id])
  apiKey   ApiKey   @relation(fields: [apiKeyId], references: [id])

  @@index([businessId])
}

// ═══════════════════════════════════════════════════════════════
// TEAM HUB
// ═══════════════════════════════════════════════════════════════

enum TeamRole {
  SUPER_ADMIN
  COO
  AGENT_MANAGER
  GRAPHISTE
  SUPPORT
  CAMERAMAN
  MODEL
}

enum TeamChannelType {
  PUBLIC
  PRIVATE
  DIRECT
}

enum TeamTaskPriority {
  URGENT
  NORMAL
  BAS
}

enum TeamTaskStatus {
  TODO
  EN_COURS
  REVIZYON
  FINI
}

enum TeamFileCategory {
  DESIGN
  VIDEO
  PHOTO
  DOCUMENT
  OTHER
}

enum TeamReportType {
  DAILY
  WEEKLY
  MONTHLY
}

enum TeamReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

enum TeamAnnouncementPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum TeamCalendarEventType {
  MEETING
  DEADLINE
  LAUNCH
  OTHER
}

enum TeamNotificationType {
  MESSAGE
  TASK
  REPORT
  ANNOUNCEMENT
  CALENDAR
  MEETING
}

model TeamInvitation {
  id          String   @id @default(uuid())
  email       String   @unique
  role        TeamRole
  displayName String
  token       String   @unique
  expiresAt   DateTime
  accepted    Boolean  @default(false)
  invitedById String
  createdAt   DateTime @default(now())

  @@index([token])
  @@index([email])
}

model TeamMember {
  id          String   @id @default(uuid())
  userId      String   @unique
  role        TeamRole
  displayName String
  avatar      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  createdChannels TeamChannel[]       @relation("TeamChannelCreator")
  channels        TeamChannel[]       @relation("TeamChannelMembers")
  messages        TeamMessage[]       @relation("TeamMessageSender")
  assignedTasks   TeamTask[]          @relation("TeamTaskAssignee")
  createdTasks    TeamTask[]          @relation("TeamTaskAssigner")
  taskComments    TeamTaskComment[]   @relation("TeamTaskCommentAuthor")
  uploadedFiles   TeamFile[]          @relation("TeamFileUploader")
  reports         TeamReport[]        @relation("TeamReportAuthor")
  announcements   TeamAnnouncement[]  @relation("TeamAnnouncementAuthor")
  createdEvents   TeamCalendarEvent[] @relation("TeamCalendarEventCreator")
  attendingEvents TeamCalendarEvent[] @relation("TeamCalendarEventAttendees")
  notifications   TeamNotification[]  @relation("TeamNotificationRecipient")

  @@index([role])
  @@index([isActive])
}

model TeamChannel {
  id          String          @id @default(uuid())
  name        String
  description String?
  type        TeamChannelType @default(PUBLIC)
  createdById String
  createdAt   DateTime        @default(now())

  createdBy TeamMember    @relation("TeamChannelCreator", fields: [createdById], references: [id])
  members   TeamMember[]  @relation("TeamChannelMembers")
  messages  TeamMessage[]

  @@index([createdById])
  @@index([type])
}

model TeamMessage {
  id        String    @id @default(uuid())
  channelId String
  senderId  String
  content   String
  fileUrl   String?
  fileType  String?
  replyToId String?
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  channel TeamChannel   @relation(fields: [channelId], references: [id])
  sender  TeamMember    @relation("TeamMessageSender", fields: [senderId], references: [id])
  replyTo TeamMessage?  @relation("TeamMessageReplies", fields: [replyToId], references: [id])
  replies TeamMessage[] @relation("TeamMessageReplies")

  @@index([channelId])
  @@index([senderId])
  @@index([replyToId])
  @@index([createdAt])
}

model TeamTask {
  id           String           @id @default(uuid())
  title        String
  description  String?
  assignedToId String
  assignedById String
  priority     TeamTaskPriority @default(NORMAL)
  status       TeamTaskStatus   @default(TODO)
  deadline     DateTime?
  projectTag   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignedTo TeamMember        @relation("TeamTaskAssignee", fields: [assignedToId], references: [id])
  assignedBy TeamMember        @relation("TeamTaskAssigner", fields: [assignedById], references: [id])
  comments   TeamTaskComment[]
  files      TeamFile[]

  @@index([assignedToId])
  @@index([assignedById])
  @@index([status])
  @@index([priority])
  @@index([projectTag])
}

model TeamTaskComment {
  id        String   @id @default(uuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  task   TeamTask   @relation(fields: [taskId], references: [id])
  author TeamMember @relation("TeamTaskCommentAuthor", fields: [authorId], references: [id])

  @@index([taskId])
  @@index([authorId])
}

model TeamFile {
  id           String           @id @default(uuid())
  name         String
  url          String
  size         Int
  mimeType     String
  uploadedById String
  category     TeamFileCategory @default(OTHER)
  description  String?
  taskId       String?
  createdAt    DateTime         @default(now())

  uploadedBy TeamMember @relation("TeamFileUploader", fields: [uploadedById], references: [id])
  task       TeamTask?  @relation(fields: [taskId], references: [id])

  @@index([uploadedById])
  @@index([category])
  @@index([taskId])
}

model TeamReport {
  id          String           @id @default(uuid())
  title       String
  content     String
  authorId    String
  type        TeamReportType
  status      TeamReportStatus @default(DRAFT)
  reviewNote  String?
  createdAt   DateTime         @default(now())
  submittedAt DateTime?
  reviewedAt  DateTime?

  author TeamMember @relation("TeamReportAuthor", fields: [authorId], references: [id])

  @@index([authorId])
  @@index([status])
  @@index([type])
}

model TeamAnnouncement {
  id        String                   @id @default(uuid())
  title     String
  content   String
  authorId  String
  priority  TeamAnnouncementPriority @default(NORMAL)
  createdAt DateTime                 @default(now())

  author TeamMember @relation("TeamAnnouncementAuthor", fields: [authorId], references: [id])

  @@index([authorId])
  @@index([priority])
}

model TeamCalendarEvent {
  id             String                @id @default(uuid())
  title          String
  description    String?
  startAt        DateTime
  endAt          DateTime
  type           TeamCalendarEventType @default(OTHER)
  createdById    String
  meetingUrl     String?
  isJitsiMeeting Boolean               @default(false)
  jitsiRoomId    String?
  reminderSent   Boolean               @default(false)
  createdAt      DateTime              @default(now())

  createdBy TeamMember   @relation("TeamCalendarEventCreator", fields: [createdById], references: [id])
  attendees TeamMember[] @relation("TeamCalendarEventAttendees")

  @@index([createdById])
  @@index([type])
  @@index([startAt])
}

model TeamNotification {
  id          String               @id @default(uuid())
  recipientId String
  type        TeamNotificationType
  title       String
  content     String
  isRead      Boolean              @default(false)
  link        String?
  createdAt   DateTime             @default(now())

  recipient TeamMember @relation("TeamNotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([isRead])
}
