# ── Server ─────────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=development
FRONTEND_URL=https://ozamapay.com
BACKEND_URL=https://api.ozamapay.com

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ozamapay

# ── Auth ────────────────────────────────────────────────────────────────────────
JWT_SECRET=
OZAMAPAY_MASTER_ID=

# ── Sentry Error Tracking ───────────────────────────────────────────────────────
# Ajoute DSN la depi Sentry dashboard apre ou kreye projet la
SENTRY_DSN=

# ── Strowallet (Virtual Cards) ──────────────────────────────────────────────────
STROWALLET_PUBLIC_KEY=
STROWALLET_WEBHOOK_SECRET=

# ── Brevo (Email) ────────────────────────────────────────────────────────────────
BREVO_API_KEY=

# ── ImageKit (KYC Photo Storage) ────────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# ── MonCash (Payment Gateway) ───────────────────────────────────────────────────
MONCASH_CLIENT_ID=
MONCASH_SECRET_KEY=
MONCASH_MODE=sandbox
MONCASH_WEBHOOK_SECRET=
MONCASHCONNECT_SECRET_KEY=
MONCASHCONNECT_WEBHOOK_SECRET=

# ── Reloadly (Airtime / Gift Cards) ─────────────────────────────────────────────
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_WEBHOOK_SECRET=

# ── USDT (TRC20) Deposits ────────────────────────────────────────────────────────
# BIP39 mnemonic — HD wallet master seed. Never commit a real value. No
# individual private keys are ever stored in the DB; addresses are
# re-derived from this seed + DepositAddress.derivationIndex on demand.
TRON_MASTER_MNEMONIC=
TRONGRID_API_KEY=
TRONGRID_BASE_URL=https://api.trongrid.io
USDT_TRC20_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
USDT_MIN_CONFIRMATIONS=20

# ── Google OAuth ─────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
